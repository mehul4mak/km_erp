<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_qa" model="ir.ui.view">
        <field name="name">mrp.production.form.qa.gates</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Quality Gates" name="qa_gates">
                    <field name="quality_check_ids" readonly="1">
                        <tree>
                            <field name="checkpoint"/>
                            <field name="state"/>
                            <field name="note"/>
                            <field name="checked_by"/>
                            <field name="checked_on"/>
                        </tree>
                    </field>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
